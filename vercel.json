{
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/api/chat/?$", "dest": "/api/chat.js" },
    { "src": "^/api/football/?$", "dest": "/api/football.js" },
    { "src": "^/api/admin/?$", "dest": "/api/admin.js" },
    { "src": "^/api/stats/?$", "dest": "/api/stats.js" },
    { "src": "^/api/news/?$", "dest": "/api/news.js" },
    { "src": "^/api/image-proxy/?$", "dest": "/api/image-proxy.js" },

    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
